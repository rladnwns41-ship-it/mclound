async function newKey(){const r=await api('POST','/api/auth/keys',{name:V('newKeyN')||'key'});if(r.error)return toast(r.error,0);toast('발급: '+r.api_key.substring(0,15)+'...');navigator.clipboard?.writeText(r.api_key);keyList();}
async function keyList(){
  const r=await api('GET','/api/auth/keys');
  if(!r.keys?.length){$('keyListEl').innerHTML='<div class="empty">없음</div>';return;}
  const tagFor=t=>t==='anon'?'<span class="tag tag-b">anon</span>':t==='secret'?'<span class="tag tag-r">secret</span>':'<span class="tag tag-g">user</span>';
  $('keyListEl').innerHTML=`<table class="tbl"><tr><th>타입</th><th>이름</th><th>키</th><th></th></tr>${r.keys.map(k=>`<tr>
    <td>${tagFor(k.key_type||'user')}</td>
    <td>${esc(k.name||'-')}</td>
    <td class="mono">${esc(k.key.substring(0,20))}...</td>
    <td>${k.key===K?'<span class="tag tag-g">현재</span>':(k.key_type==='anon'||k.key_type==='secret')?'<span style="color:var(--text3);font-size:11px">시스템</span>':`<button class="btn btn-d btn-sm" onclick="delKey(${JSON.stringify(k.key)})">삭제</button>`}</td>
  </tr>`).join('')}</table>`;
}
async function delKey(k){if(!await customConfirm('삭제 확인','정말 삭제할까요?',{okText:'삭제',danger:true}))return;const r=await api('DELETE','/api/auth/keys/'+encodeURIComponent(k));if(r.error)return toast(r.error,0);toast('삭제됨');keyList();}

// ===== ANON / SECRET =====
let _secKey='',_secShow=false;
async function specialKeys(){
  const r=await api('GET','/api/auth/keys');
  if(r.error)return;
  const anon=r.keys.find(k=>k.key_type==='anon');
  const sec=r.keys.find(k=>k.key_type==='secret');
  $('anonKey').textContent=anon?anon.key:'(없음)';
  _secKey=sec?sec.key:'';
  $('secretKey').textContent=_secShow&&_secKey?_secKey:'••••••••••••••••••••••••••••';
}
function toggleSecret(){
  _secShow=!_secShow;
  $('secretKey').textContent=_secShow&&_secKey?_secKey:'••••••••••••••••••••••••••••';
  $('secEye').setAttribute('data-lucide',_secShow?'eye-off':'eye');renderIcons();
}
function copyText(txt,msg){if(!txt||txt.startsWith('•')||txt==='(없음)'||txt==='-')return toast('복사할 값이 없음',0);navigator.clipboard?.writeText(txt);toast(msg||'복사됨');}
async function rotateKey(kind){
  if(!await customConfirm(`${kind} 키 재발급`,`기존 ${kind} 키는 즉시 무효화됩니다. 계속?`,{okText:'재발급',danger:true}))return;
  const r=await api('POST','/api/auth/keys/rotate',{kind});
  if(r.error)return toast(r.error,0);
  toast(kind+' 키 재발급 완료');specialKeys();keyList();
}

