  el.innerHTML=`<table class="tbl"><tr><th>사용자명</th><th>ID</th><th>API Keys</th><th>EC2</th><th>Lambda</th><th>버킷</th><th>사이트</th><th>가입일</th></tr>
    ${r.users.map(u=>`<tr>
      <td><strong>${u.username}</strong></td>
      <td class="mono">${u.id.substring(0,12)}...</td>
      <td>${u.key_count}</td>
      <td>${u.ec2_count}</td>
      <td>${u.lambda_count}</td>
      <td>${u.bucket_count}</td>
      <td>${u.site_count}</td>
      <td style="color:var(--text3)">${u.created_at||''}</td>
    </tr>`).join('')}</table>`;
