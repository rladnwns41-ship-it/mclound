};
function icon(name,w=17,h=17){return`<svg viewBox="0 0 24 24" width="${w}" height="${h}" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ICONS[name]||''}</svg>`}
function renderIcons(){document.querySelectorAll('[data-lucide]').forEach(el=>{const n=el.getAttribute('data-lucide');const w=el.style.width?parseInt(el.style.width):17;const h=el.style.height?parseInt(el.style.height):17;if(ICONS[n])el.outerHTML=icon(n,w,h);});}
window.addEventListener('DOMContentLoaded',()=>renderIcons());

let B='',K='',U='';
const $=id=>document.getElementById(id);
const V=id=>$(id)?.value?.trim()||'';
// XSS 방지: 유저 데이터 innerHTML 삽입 전 반드시 esc()로 감쌀 것
const esc=s=>s==null?'':String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');

// ===== CUSTOM DROPDOWN =====
function ddToggle(id){
  const dd=$(id)||document.querySelector(`[data-dd="${id}"]`);
  if(!dd)return;
  const trigger=dd.querySelector('.dd-trigger');
  const menu=dd.querySelector('.dd-menu');
  const isOpen=trigger.classList.contains('open');
  // 모든 드롭다운 닫기
  document.querySelectorAll('.dd-trigger.open').forEach(t=>{t.classList.remove('open');t.nextElementSibling.classList.remove('open');});
  if(!isOpen){trigger.classList.add('open');menu.classList.add('open');}
}
function ddSelect(id,val,el){
  const dd=$(id);
  // 값 업데이트
  const hidden=document.getElementById(id.replace('dd-','')+'T')||document.getElementById(id.replace('dd-','')+'Svc');
  if(hidden)hidden.value=val;
  // 표시 텍스트
  $(id+'-val').textContent=el.textContent.replace('✓','').trim();
  // 선택 표시
  dd.querySelectorAll('.dd-opt').forEach(o=>o.classList.remove('sel'));
  el.classList.add('sel');
  // 닫기
  dd.querySelector('.dd-trigger').classList.remove('open');
  dd.querySelector('.dd-menu').classList.remove('open');
}
document.addEventListener('click',e=>{
  if(!e.target.closest('.dd')){
    document.querySelectorAll('.dd-trigger.open').forEach(t=>{
      t.classList.remove('open');
      t.nextElementSibling.classList.remove('open');
    });
  }
});

// ===== TOAST =====
function toast(m,ok=true){const d=document.createElement('div');d.className='toast '+(ok?'ok':'err');d.textContent=m;$('toasts').appendChild(d);setTimeout(()=>{d.style.opacity='0';d.style.transition='.3s';setTimeout(()=>d.remove(),300)},3000)}

// ===== API =====
async function api(method,path,body,auth=true){
  try{
    const o={method,headers:{'Content-Type':'application/json','ngrok-skip-browser-warning':'true'}};
    if(auth&&K)o.headers['X-API-Key']=K;
    if(body&&method!=='GET')o.body=JSON.stringify(body);
    const r=await fetch(B+path,o);return await r.json();
  }catch(e){return{error:e.message}}
}
async function upload(path,fd){
  try{const o={method:'POST',headers:{'X-API-Key':K,'ngrok-skip-browser-warning':'true'},body:fd};const r=await fetch(B+path,o);return await r.json();}catch(e){return{error:e.message}}
}
function show(id,d,ok=true){const e=$(id);if(!e)return;e.style.display='block';e.textContent=typeof d==='string'?d:JSON.stringify(d,null,2);e.style.borderLeft=ok?'2px solid var(--green)':'2px solid var(--red)'}
function fmtB(b){return b>1048576?(b/1048576).toFixed(1)+' MB':b>1024?(b/1024).toFixed(1)+' KB':b+' B'}

// ===== AUTH =====
// ===== 로그인 화면 =====
let _loginMode = 'login'; // 'login' | 'register'
let _srvCheckTimer = null;

function switchLoginTab(mode) {
  _loginMode = mode;
  $('tabLogin').classList.toggle('active', mode === 'login');
  $('tabRegister').classList.toggle('active', mode === 'register');
  $('loginBtnTxt').textContent = mode === 'login' ? '로그인' : '회원가입';
  loginErrHide(); loginOkHide();
}

function loginErr(msg) {
  const el = $('loginErr'); $('loginErrTxt').textContent = msg;
  el.classList.add('show'); $('loginOk').classList.remove('show');
}
function loginErrHide() { $('loginErr').classList.remove('show'); }
function loginOk(msg) {
  const el = $('loginOk'); $('loginOkTxt').textContent = msg;
  el.classList.add('show'); $('loginErr').classList.remove('show');
}
function loginOkHide() { $('loginOk').classList.remove('show'); }

function setLoginLoading(on) {
  const btn = $('loginActionBtn');
  btn.disabled = on;
  $('loginBtnTxt').textContent = on ? '연결 중...' : (_loginMode === 'login' ? '로그인' : '회원가입');
}

async function loginAction() {
  const u = V('iUser'), p = V('iPass'), s = V('iSrv').replace(/\/$/, '');
  if (!u || !p) return loginErr('사용자명과 비밀번호를 입력해주세요');
  if (!s) return loginErr('서버 URL을 입력해주세요');
  B = s;
  setLoginLoading(true); loginErrHide(); loginOkHide();
  const endpoint = _loginMode === 'login' ? '/api/auth/login' : '/api/auth/register';
  try {
    const r = await fetch(B + endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'ngrok-skip-browser-warning': 'true' },
      body: JSON.stringify({ username: u, password: p }),
      signal: AbortSignal.timeout(15000)
    }).then(r => r.json()).catch(e => ({ error: e.message }));
    setLoginLoading(false);
    if (r.error) { loginErr(r.error); return; }
    if (!r.api_key) { loginErr('서버 응답 오류 (api_key 없음)'); return; }
    if (_loginMode === 'register') loginOk('가입 완료! 로그인 중...');
    K = r.api_key; U = u;
    setTimeout(onAuth, _loginMode === 'register' ? 600 : 0);
  } catch(e) {
    setLoginLoading(false);
    loginErr('서버 연결 실패: ' + e.message);
  }
}

// 이전 호환성
function doLogin() { _loginMode = 'login'; loginAction(); }
function doRegister() { _loginMode = 'register'; loginAction(); }

// 서버 URL 입력 시 실시간 상태 체크
function onSrvInput() {
  if (_srvCheckTimer) clearTimeout(_srvCheckTimer);
  setSrvStatus('checking', '확인 중...');
  _srvCheckTimer = setTimeout(checkSrvStatus, 700);
}

function setSrvStatus(state, msg) {
  const dot = $('srvDot'), txt = $('srvMsg');
  dot.className = 'srv-dot ' + state;
  txt.textContent = msg;
  txt.style.color = state === 'ok' ? '#16a34a' : state === 'fail' ? '#dc2626' : 'var(--text3)';
}

async function checkSrvStatus() {
  const s = V('iSrv').replace(/\/$/, '');
  if (!s) return setSrvStatus('fail', 'URL을 입력하세요');
  setSrvStatus('checking', '연결 확인 중...');
  try {
    const r = await fetch(s + '/api/cloudwatch/summary', {
      headers: { 'ngrok-skip-browser-warning': 'true' },
      signal: AbortSignal.timeout(10000)
    });
    if (r.status === 401 || r.ok) {
      setSrvStatus('ok', '서버 온라인 ✓');
    } else {
      setSrvStatus('fail', `서버 응답 오류 (${r.status})`);
    }
  } catch(e) {
    const msg = e.name === 'TimeoutError' ? '응답 없음 (타임아웃)' :
                e.message.includes('fetch') ? '서버에 연결할 수 없음' : e.message;
    setSrvStatus('fail', '😴 서버 슬립 중 또는 오프라인');
  }
}

// (서버 상태 초기 체크는 메인 DOMContentLoaded에서 처리)
// ============ 화면 전환 ============
// 4개 화면: landing, login, projects, app
function showScreen(name){
  ['lndScr','loginScr','prjScr','app'].forEach(id=>$(id)?.classList.remove('show'));
  const map={landing:'lndScr',login:'loginScr',projects:'prjScr',app:'app'};
  const el=$(map[name]);if(el)el.classList.add('show');
  if(name==='projects')prjLoad();
}

function onAuth(){
  $('avatar').textContent=U[0]?.toUpperCase()||'U';
  $('curKey').textContent=K;
  $('setUser').value=U;$('setSrv').value=B;
  $('prjUser').textContent=U;
  $('keyEx').textContent=`curl -H "X-API-Key: ${K}" ${B}/api/cloudwatch/summary\n\n# Python\nfrom aoaocloud_client import AOAOCloud\ncloud = AOAOCloud("${B}", "${K}")\nprint(cloud.cloudwatch.summary())`;
  localStorage.setItem('ak',K);localStorage.setItem('au',U);localStorage.setItem('ab',B);
  renderIcons();startAliveCheck();
  showScreen('projects');  // 로그인 후엔 프로젝트 목록으로
}
function logout(){localStorage.clear();K='';U='';location.reload();}

// ============ 프로젝트 목록 ============
async function prjLoad(){
  const el=$('prjGrid');el.innerHTML='<div class="empty">로딩 중...</div>';
  const r=await api('GET','/api/projects');
  if(r.error){el.innerHTML=`<div class="code" style="border-left:2px solid var(--red)">${esc(r.error)}</div>`;return;}
  const cards=r.projects.map(p=>{
    const initial=(p.name||'?')[0].toUpperCase();
    const created=(p.created_at||'').split(' ')[0];
    return `<div class="prj-card" onclick="prjEnter(${JSON.stringify(p.id)},${JSON.stringify(p.name)})">
      <button class="prj-card-del" onclick="event.stopPropagation();prjDel(${JSON.stringify(p.id)},${JSON.stringify(p.name)})" title="삭제"><i data-lucide="trash-2" style="width:14px;height:14px"></i></button>
      <div class="prj-card-icon">${esc(initial)}</div>
      <h3>${esc(p.name)}</h3>
      <div class="prj-card-desc">${esc(p.description||'설명 없음')}</div>
      <div class="prj-card-meta"><span>📍 ${esc(p.region||'서울')}</span><span>${esc(created)}</span></div>
    </div>`;
  }).join('');
  const newCard=`<div class="prj-card prj-card-new" onclick="prjNew()">
    <i data-lucide="plus-circle" style="width:36px;height:36px;margin-bottom:12px;opacity:.6"></i>
    <div style="font-weight:600">새 프로젝트</div>
    <div style="font-size:11px;margin-top:4px">클릭해서 만들기</div>
  </div>`;
  el.innerHTML=cards+newCard;renderIcons();
}

async function prjNew(){
  const name=await customPrompt('새 프로젝트',{placeholder:'my-awesome-app',msg:'프로젝트 이름을 입력하세요.'});
  if(!name)return;
  const r=await api('POST','/api/projects',{name:name.trim()});
  if(r.error)return toast(r.error,0);
  toast('생성: '+name);prjLoad();
}

async function prjDel(id,name){
  if(!await customConfirm('프로젝트 삭제',`'${name}'을 삭제할까요? 프로젝트 안의 데이터는 그대로 유지되지만, 목록에서 사라집니다.`,{okText:'삭제',danger:true}))return;
  const r=await api('DELETE','/api/projects/'+encodeURIComponent(id));
  if(r.error)return toast(r.error,0);
  toast('삭제됨');prjLoad();
}

function prjEnter(id,name){
  CUR_PROJ=id;
  localStorage.setItem('curp_'+U,id);
  $('projLabel').textContent=name;
  showScreen('app');
  nav('dash',document.querySelector('.sb-btn'));
  loadDash();startDashAutoRefresh();
}
function prjBack(){
  stopDashAutoRefresh?.();
  showScreen('projects');
}

window.addEventListener('DOMContentLoaded',()=>{
  renderIcons();
  const k=localStorage.getItem('ak'),u=localStorage.getItem('au'),b=localStorage.getItem('ab');
  if(k&&u&&b){K=k;U=u;B=b;
    $('iSrv').value=b;
    setSrvStatus('checking','확인 중...');
    fetch(B+'/api/cloudwatch/summary',{headers:{'X-API-Key':K,'ngrok-skip-browser-warning':'true'},signal:AbortSignal.timeout(10000)}).then(r=>{
      if(r.ok||r.status===200){onAuth();}else{
        localStorage.clear();
        showScreen('landing');
        setSrvStatus('ok','서버 온라인 ✓');
      }
    }).catch(()=>{
      localStorage.clear();
      showScreen('landing');
    });
  } else {
    showScreen('landing');
    setTimeout(checkSrvStatus, 500);
  }
});
function copyKey(){navigator.clipboard?.writeText(K);toast('복사됨!')}

// ===== NAV =====
function nav(id,el){
  document.querySelectorAll('#page-area > *').forEach(p=>{
    p.style.display='none';
    p.classList.remove('show-page');
  });
  const pg=$('pg-'+id);
  if(pg){
    if(pg.classList.contains('pg-with-sb')){
      pg.classList.add('show-page');
    } else {
      pg.style.display='block';
    }
  }
  document.querySelectorAll('.sb-btn').forEach(b=>b.classList.remove('active'));
  if(el)el.classList.add('active');
  if(id==='dash')loadDash();
  if(id==='keys'){specialKeys();keyList();}
  renderIcons();
}
function sp(panel,el){
  const page=el.closest('.pg-with-sb')||el.closest('[id^=pg-]');
  if(page)page.querySelectorAll('[data-panel]').forEach(p=>p.classList.remove('show'));
  const p=document.querySelector(`[data-panel="${panel}"]`);if(p)p.classList.add('show');
  const sb=el.parentElement;sb.querySelectorAll('.is-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
}

// ===== PROJECTS =====
let PROJS=[{id:'default',name:'Default'}],CUR_PROJ='default';
async function loadProjs(){
  const r=await api('GET','/api/projects');
  PROJS = r.projects||[];
  if(!PROJS.length)PROJS=[{id:'default',name:'Default'}];
  CUR_PROJ=localStorage.getItem('curp_'+U)||PROJS[0].id;
  renderProjs();
}
function saveProjs(){localStorage.setItem('curp_'+U,CUR_PROJ);}
function renderProjs(){
  const cur=PROJS.find(p=>p.id===CUR_PROJ);
  $('projLabel').textContent=cur?.name||'Default';
  $('projList').innerHTML=PROJS.map(p=>`<div class="proj-dd-item ${p.id===CUR_PROJ?'active':''}" onclick="switchProj(${JSON.stringify(p.id)})">${esc(p.name)}${p.id===CUR_PROJ?' ✓':''}</div>`).join('');
}
function switchProj(id){
  const p=PROJS.find(x=>x.id===id);if(!p)return;
  CUR_PROJ=id;saveProjs();renderProjs();
  $('projDD').classList.remove('open');
  toast('프로젝트: '+p.name);
}
async function newProject(){
  $('projDD').classList.remove('open');
  const n=await customPrompt('새 프로젝트',{placeholder:'my-project',msg:'프로젝트 이름을 입력하세요.'});
  if(!n)return;
  const r=await api('POST','/api/projects',{name:n.trim()});
  if(r.error)return toast(r.error,0);
  await loadProjs();
  CUR_PROJ=r.id;saveProjs();renderProjs();
  toast('프로젝트 생성: '+n);
}
document.addEventListener('click',e=>{if(!e.target.closest('#projBtn'))$('projDD')?.classList.remove('open');});

// ===== DASHBOARD =====
const SVCS=[
  {id:'ec2',name:'EC2',desc:'가상 머신',icon:'monitor',color:'var(--orange)'},
  {id:'lambda',name:'Lambda',desc:'서버리스',icon:'zap',color:'var(--purple)'},
  {id:'s3',name:'S3',desc:'스토리지',icon:'database',color:'var(--cyan)'},
  {id:'database',name:'데이터베이스',desc:'SQL + 테이블 + RLS',icon:'database-zap',color:'var(--green)'},
  {id:'storage',name:'스토리지',desc:'EBS, CF 등',icon:'hard-drive',color:'var(--red)'},
  {id:'deploy',name:'배포',desc:'Lightsail, EB',icon:'rocket',color:'var(--yellow)'},
  {id:'security',name:'보안',desc:'VPC, Auto',icon:'shield',color:'var(--orange)'},
  {id:'watch',name:'CloudWatch',desc:'모니터링',icon:'bar-chart-3',color:'var(--cyan)'},
  {id:'keys',name:'API Keys',desc:'키 관리',icon:'key',color:'var(--green)'},
  {id:'docs',name:'API 문서',desc:'레퍼런스',icon:'file-text',color:'var(--purple)'},
];
function renderSvcGrid(){$('svcGrid').innerHTML=SVCS.map(s=>`<div class="svc-card" onclick="nav('${s.id}')"><div class="svc-icon" style="background:${s.color}15;color:${s.color};border-color:${s.color}30"><i data-lucide="${s.icon}"></i></div><div class="svc-name">${s.name}</div><div class="svc-desc">${s.desc}</div></div>`).join('');renderIcons();}
async function loadDash(){
  renderSvcGrid();loadProjs();loadActivity();
  const r=await api('GET','/api/cloudwatch/summary');
  if(!r.error){const s=r.storage||{},v=r.services||{};$('st-sto').textContent=fmtB(s.total_bytes||0);$('st-ec2').textContent=v.ec2_running||0;$('st-lam').textContent=v.lambda_functions||0;$('st-site').textContent=v.lightsail_sites||0;}
  const d=await api('GET','/api/cloudwatch/dashboard?hours=24');
  if(!d.error){$('st-req').textContent=d.total_requests||0;$('st-avg').textContent=(d.avg_response_ms||0)+'ms';$('st-err').textContent=d.error_count||0;$('st-rate').textContent=(d.error_rate||0)+'%';
  const svcs=d.by_service||[];const mx=Math.max(...svcs.map(s=>s.count),1);
  const colors={S3:'var(--cyan)',EC2:'var(--orange)',Lambda:'var(--purple)',Auth:'var(--green)',CloudWatch:'var(--blue)',Other:'var(--dim)'};
  $('svcBars').innerHTML=svcs.length?'<div class="bar-wrap">'+svcs.map(s=>{const p=Math.round(s.count/mx*100);return`<div class="bar-row"><div class="bar-label">${s.service}</div><div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${colors[s.service]||'var(--dim)'}"></div></div><div class="bar-val">${s.count}</div></div>`}).join('')+'</div>':'<div class="empty">아직 요청 없음</div>';
  const ok=d.total_requests-(d.error_count||0),er=d.error_count||0;
  $('statusSummary').innerHTML=`<div style="display:flex;gap:20px;align-items:center"><div style="text-align:center"><div style="font-size:20px;font-weight:700;color:var(--green)">${ok}</div><div style="font-size:10px;color:var(--text3)">성공</div></div><div style="text-align:center"><div style="font-size:20px;font-weight:700;color:var(--red)">${er}</div><div style="font-size:10px;color:var(--text3)">에러</div></div><div style="text-align:center"><div style="font-size:20px;font-weight:700;color:var(--yellow)">${d.avg_response_ms||0}ms</div><div style="font-size:10px;color:var(--text3)">평균 응답</div></div></div>`;}
}

// ===== EC2 =====
async function ec2Create(){const r=await api('POST','/api/ec2/instances',{name:V('ec2Name')||'inst'});if(r.error)return toast(r.error,0);toast('생성: '+r.instance_id);$('ec2Name').value='';ec2List();}
async function ec2List(){const r=await api('GET','/api/ec2/instances');$('ec2ListEl').innerHTML=r.instances?.length?`<table class="tbl"><tr><th>이름</th><th>ID</th><th>상태</th><th></th></tr>${r.instances.map(i=>`<tr><td>${i.name}</td><td class="mono">${i.id}</td><td><span class="tag tag-${i.status==='running'?'g':'r'}">${i.status}</span></td><td>${i.status==='running'?`<button class="btn btn-p btn-sm" onclick="ec2Connect('${i.id}')">연결</button>`:''}</td></tr>`).join('')}</table>`:'<div class="empty">없음</div>';}
function ec2Connect(id){$('ec2TermId').value=id;sp('ec2-term',document.querySelectorAll('.pg-with-sb')[0].querySelectorAll('.is-item')[1]);$('termBody').innerHTML='$ '+id+' 에 연결됨\n';$('termCmd').focus();toast('터미널 연결: '+id);}
let _ec2CmdHistory=[], _ec2HistIdx=-1;

function ec2TermKeydown(e) {
  if (e.key==='Enter'){ec2Exec();return;}
  if (e.key==='ArrowUp'){e.preventDefault();if(!_ec2CmdHistory.length)return;_ec2HistIdx=Math.min(_ec2HistIdx+1,_ec2CmdHistory.length-1);$('termCmd').value=_ec2CmdHistory[_ec2HistIdx]||'';}
  if (e.key==='ArrowDown'){e.preventDefault();_ec2HistIdx=Math.max(_ec2HistIdx-1,-1);$('termCmd').value=_ec2HistIdx>=0?(_ec2CmdHistory[_ec2HistIdx]||''):'';}
}

function ec2TermTabSwitch(tabId,el){
  ['tab-ec2-term','tab-ec2-files','tab-ec2-hist'].forEach(id=>{const t=$(id);if(t)t.style.display='none';});
  const target=$(tabId);if(target)target.style.display='block';
  document.querySelectorAll('[data-ec2tab]').forEach(t=>t.classList.remove('active'));
  if(el)el.classList.add('active');
  if(tabId==='tab-ec2-files')ec2FilesList();
  if(tabId==='tab-ec2-hist')ec2HistLoad();
  renderIcons();
}

async function ec2Exec(){
  const cmd=V('termCmd'),id=V('ec2TermId');
  if(!cmd||!id)return;
  if(_ec2CmdHistory[0]!==cmd)_ec2CmdHistory.unshift(cmd);
  if(_ec2CmdHistory.length>100)_ec2CmdHistory.pop();
  _ec2HistIdx=-1;
  const b=$('termBody');
  b.innerHTML+=`\n<span style="color:var(--green)">$ ${cmd}</span>\n`;
  $('termCmd').value='';
  await _ec2Run(id,cmd,b,false);
}

async function ec2FilesList(){
  const id=V('ec2TermId');if(!id)return;
  const r=await api('GET',`/api/ec2/files?instance_id=${id}`);
  const el=$('ec2FilesEl');
  if(r.error){el.innerHTML=`<div class="empty">${r.error}</div>`;return;}
  if(!r.files?.length){el.innerHTML='<div class="empty">파일 없음</div>';return;}
  el.innerHTML=`<div style="font-size:11px;color:var(--text3);margin-bottom:8px">${r.work_dir||''}</div>
    <table class="tbl"><tr><th>이름</th><th>크기</th><th></th></tr>
    ${r.files.map(f=>`<tr><td>${f.is_dir?'📁':'📄'} ${f.name}</td><td>${f.is_dir?'-':fmtB(f.size)}</td>
    <td>${!f.is_dir?`<a href="${B}/api/ec2/download?instance_id=${id}&filename=${encodeURIComponent(f.name)}&api_key=${K}" class="btn btn-s btn-sm" download>⬇</a>`:''}</td></tr>`).join('')}</table>`;
}

async function ec2FileUpload(){
  const id=V('ec2TermId');const file=$('ec2UpFile').files[0];
  if(!id||!file)return toast('인스턴스 ID를 먼저 입력하세요',0);
  const fd=new FormData();fd.append('instance_id',id);fd.append('file',file);
  const r=await upload('/api/ec2/upload',fd);
  if(r.error)return toast(r.error,0);
  toast('업로드 완료: '+r.filename);ec2FilesList();
}

async function ec2HistLoad(){
  const id=V('ec2TermId');
  const r=await api('GET',id?`/api/ec2/history?instance_id=${id}`:'/api/ec2/history');
  const el=$('ec2HistEl');
  if(r.error){el.innerHTML=`<div class="empty">${r.error}</div>`;return;}
  if(!r.history?.length){el.innerHTML='<div class="empty">히스토리 없음</div>';return;}
  el.innerHTML=`<table class="tbl"><tr><th>시간</th><th>명령어</th><th>상태</th></tr>
    ${r.history.map(h=>`<tr><td style="color:var(--text3);white-space:nowrap">${(h.executed_at||'').substring(0,19)}</td>
    <td class="mono">${h.command||''}</td>
    <td>${h.is_blocked?'<span class="tag tag-r">차단</span>':'<span class="tag tag-g">OK</span>'}</td></tr>`).join('')}</table>`;
}

async function lsDel(id){if(!await customConfirm('삭제 확인','정말 삭제할까요?',{okText:'삭제',danger:true}))return;const r=await api('DELETE','/api/lightsail/sites/'+id);if(r.error)return toast(r.error,0);toast('삭제 완료');lsList();}

async function lsEdit(id){
  const r=await api('GET','/api/lightsail/sites/'+id+'/html');if(r.error)return toast(r.error,0);
  $('lsH').value=r.html||'';toast('HTML 로드됨 - 수정 후 배포 버튼 클릭');
}

async function ebsDataList(){
  const vol=V('ebsV');const r=await api('GET',vol?'/api/ebs/list?volume='+vol:'/api/ebs/list');
  const el=$('ebsRes');el.style.display='block';
  if(r.error){el.textContent=r.error;el.style.borderLeft='2px solid var(--red)';return;}
  if(!r.data?.length){el.textContent='데이터 없음';return;}
  el.style.borderLeft='2px solid var(--green)';
  el.innerHTML=`<table class="tbl"><tr><th>키</th><th>원본</th><th>압축</th></tr>
    ${r.data.map(d=>`<tr><td class="mono">${d.key}</td><td>${fmtB(d.original_size)}</td><td>${fmtB(d.compressed_size)}</td></tr>`).join('')}</table>`;
}

async function changePw(){
  const cur=V('pwCur'),nw=V('pwNew'),nw2=V('pwNew2');
  if(!cur||!nw)return toast('모두 입력해주세요',0);
  if(nw!==nw2)return toast('새 비밀번호 불일치',0);
  const r=await api('POST','/api/auth/change-password',{current_password:cur,new_password:nw});
  if(r.error)return toast(r.error,0);
  toast('비밀번호 변경 완료');$('pwCur').value=$('pwNew').value=$('pwNew2').value='';
}

let _dashRefreshTimer=null;
function startDashAutoRefresh(){if(_dashRefreshTimer)clearInterval(_dashRefreshTimer);_dashRefreshTimer=setInterval(()=>{const d=$('pg-dash');if(d&&d.style.display!=='none')loadDash();},30000);}
function stopDashAutoRefresh(){if(_dashRefreshTimer){clearInterval(_dashRefreshTimer);_dashRefreshTimer=null;}}
async function _ec2Run(id,cmd,b,force){
  const r=await api('POST','/api/ec2/exec',{instance_id:id,command:cmd,force:force});
  if(r.error==='blocked'){
    b.innerHTML+=`<span style="color:var(--red)">🚫 차단됨: ${r.reason}</span>\n`;
    b.scrollTop=b.scrollHeight;return;
  }
  if(r.warning){
    b.innerHTML+=`<span style="color:var(--yellow)">⚠️ 경고: ${r.reason}</span>\n`;
    b.scrollTop=b.scrollHeight;
    const ok=await customConfirm('⚠️ 주의',r.reason+'\n\n자기 작업공간 내 데이터가 변경될 수 있습니다. 계속 실행할까요?',{okText:'계속'});
    if(ok){
      b.innerHTML+=`<span style="color:var(--yellow)">→ 사용자 확인 후 실행중...</span>\n`;
      await _ec2Run(id,cmd,b,true);
    }else{
      b.innerHTML+=`<span style="color:var(--text3)">→ 취소됨</span>\n`;
      b.scrollTop=b.scrollHeight;
    }
    return;
  }
  b.innerHTML+=r.error
    ?`<span style="color:var(--red)">❌ ${r.error} ${r.reason||''}</span>\n`
    :(r.output||'(no output)')+'\n';
  b.scrollTop=b.scrollHeight;
}

// ===== LAMBDA =====
async function lamCreate(){const r=await api('POST','/api/lambda/functions',{name:V('lamName'),code:$('lamCode').value});if(r.error)return toast(r.error,0);toast('생성: '+r.name);lamList();}
async function lamList(){const r=await api('GET','/api/lambda/functions');$('lamListEl').innerHTML=r.functions?.length?`<table class="tbl"><tr><th>이름</th><th>런타임</th><th></th></tr>${r.functions.map(f=>`<tr><td class="mono">${f.name}</td><td>${f.runtime}</td><td style="display:flex;gap:4px"><button class="btn btn-s btn-sm" onclick="lamEdit('${f.name}')">편집</button><button class="btn btn-p btn-sm" onclick="$('lamRunName').value='${f.name}';sp('lam-run',document.querySelectorAll('#pg-lambda .is-item')[2])">실행</button></td></tr>`).join('')}</table>`:'<div class="empty">없음</div>';}
async function lamEdit(name){
  const r=await api('GET','/api/lambda/functions');
  const fn=(r.functions||[]).find(f=>f.name===name);
  if(!fn)return toast('함수를 찾을 수 없습니다',0);
  $('lamName').value=fn.name;
  $('lamCode').value=fn.code||'';
  sp('lam-new',document.querySelectorAll('#pg-lambda .is-item')[1]);
  toast('코드 수정 후 생성 버튼 클릭 (같은 이름이면 덮어쓰기)');
}
async function lamInvoke(){let inp={};try{inp=JSON.parse(V('lamRunInput')||'{}');}catch{}const r=await api('POST','/api/lambda/invoke',{function:V('lamRunName'),input:inp});show('lamResult',r,r.status==='success');}

// ===== S3 =====
async function s3CreateBkt(){const n=V('s3BktName');const r=await api('POST','/api/s3/buckets',{name:n});if(r.error)return toast(r.error,0);toast('버킷 생성');$('s3BktName').value='';s3Bkts();}
async function s3Bkts(){
  const [r,rs]=await Promise.all([api('GET','/api/s3/buckets'),api('GET','/api/s3/buckets/stats')]);
  const smap={};(rs.buckets||[]).forEach(b=>smap[b.id]=b);
  $('s3BktList').innerHTML=r.buckets?.length?`<table class="tbl"><tr><th>이름</th><th>오브젝트</th><th>용량</th><th>생성일</th></tr>${r.buckets.map(b=>{const s=smap[b.id]||{};return`<tr><td><strong>${b.name}</strong></td><td>${s.object_count||0}</td><td>${fmtB(s.total_size||0)}</td><td>${b.created_at}</td></tr>`}).join('')}</table>`:'<div class="empty">버킷 없음</div>';
}
async function s3Put(){let v;try{v=JSON.parse(V('s3ObjVal'));}catch{v=V('s3ObjVal');}const r=await api('PUT','/api/s3/objects',{bucket:V('s3ObjBkt'),key:V('s3ObjKey'),value:v});show('s3Result',r,!r.error);}
async function s3Get(){const r=await api('GET',`/api/s3/objects?bucket=${V('s3ObjBkt')}&key=${V('s3ObjKey')}`);show('s3Result',r,!r.error);}
async function s3Del(){const r=await api('DELETE','/api/s3/objects',{bucket:V('s3ObjBkt'),key:V('s3ObjKey')});show('s3Result',r,!r.error);}
async function s3ObjList(){const bkt=V('s3ObjBkt');const r=await api('GET',`/api/s3/objects/list?bucket=${bkt}`);$('s3ObjListEl').innerHTML=r.objects?.length?`<table class="tbl"><tr><th>키</th><th>크기</th><th>타입</th><th></th></tr>${r.objects.map(o=>`<tr><td class="mono" style="cursor:pointer;color:var(--green)" onclick="s3Preview('${bkt}','${o.key}')">${o.key}</td><td>${fmtB(o.size)}</td><td style="color:var(--text3)">${o.content_type}</td><td><button class="btn btn-s btn-sm" onclick="s3Preview('${bkt}','${o.key}')">보기</button></td></tr>`).join('')}</table>`:'<div class="empty">오브젝트 없음</div>';}
async function s3Preview(bucket,key){
  const r=await api('GET',`/api/s3/objects?bucket=${bucket}&key=${key}`);
  const el=$('s3Result');el.style.display='block';
  if(r.error){el.textContent=r.error;el.style.borderLeft='2px solid var(--red)';return;}
  el.style.borderLeft='2px solid var(--green)';
  try{
    const val=typeof r.value==='object'?JSON.stringify(r.value,null,2):String(r.value);
    el.innerHTML='<div style="font-size:10px;color:var(--text3);margin-bottom:6px">📦 '+bucket+'/'+key+' ('+fmtB(r.size)+')</div><pre style="margin:0;white-space:pre-wrap;word-break:break-all">'+val.replace(/</g,'&lt;')+'</pre>';
  }catch{el.textContent=JSON.stringify(r,null,2);}
  $('s3ObjBkt').value=bucket;$('s3ObjKey').value=key;
}
async function s3Upload(){const f=$('s3UpFile').files[0];if(!f)return toast('파일 선택',0);const fd=new FormData();fd.append('file',f);fd.append('bucket',V('s3UpBkt'));if(V('s3UpKey'))fd.append('key',V('s3UpKey'));const r=await upload('/api/s3/upload',fd);if(r.error)return toast(r.error,0);toast(`업로드 완료: ${r.key} (${fmtB(r.size)})`);}

// ===== CUSTOM MODAL (prompt/confirm 대체) =====
let _mdlResolve=null,_mdlMode='prompt';
function customPrompt(title,{placeholder='',msg='',defaultVal='',okText='확인'}={}){
  return new Promise(res=>{
    _mdlResolve=res;_mdlMode='prompt';
    $('mdlTitle').textContent=title;
    const m=$('mdlMsg');if(msg){m.style.display='block';m.textContent=msg;}else m.style.display='none';
    $('mdlBody').style.display='block';
    const inp=$('mdlInput');inp.value=defaultVal;inp.placeholder=placeholder;inp.type='text';
    $('mdlOKBtn').textContent=okText;
    $('mdlBack').classList.add('open');setTimeout(()=>inp.focus(),50);
  });
}
function customConfirm(title,msg,{okText='확인',danger=false}={}){
  return new Promise(res=>{
    _mdlResolve=res;_mdlMode='confirm';
    $('mdlTitle').textContent=title;
    const m=$('mdlMsg');m.style.display='block';m.textContent=msg||'';
    $('mdlBody').style.display='none';
    const b=$('mdlOKBtn');b.textContent=okText;b.className='btn '+(danger?'btn-d':'btn-p');
    $('mdlBack').classList.add('open');setTimeout(()=>b.focus(),50);
  });
}
function mdlOK(){
  if(_mdlMode==='custom'&&_mdlGetter){_mdlCustomResult=_mdlGetter();}
  const r=_mdlMode==='prompt'?$('mdlInput').value:_mdlMode==='custom'?(_mdlCustomResult):true;
  $('mdlBack').classList.remove('open');$('mdlOKBtn').className='btn btn-p';
  $('mdlSlot').style.display='none';$('mdlSlot').innerHTML='';
  $('mdlBox').classList.remove('mdl-wide');_mdlGetter=null;
  if(_mdlResolve){const f=_mdlResolve;_mdlResolve=null;f(r);}
}
function mdlCancel(){
  $('mdlBack').classList.remove('open');$('mdlOKBtn').className='btn btn-p';
  $('mdlSlot').style.display='none';$('mdlSlot').innerHTML='';
  $('mdlBox').classList.remove('mdl-wide');
  if(_mdlResolve){const f=_mdlResolve;_mdlResolve=null;f(_mdlMode==='prompt'?null:_mdlMode==='custom'?null:false);}
}

// 커스텀 컨텐츠 모달 (region picker 등)
let _mdlCustomResult=null;
function customModal(title,{msg='',slotHTML='',okText='확인',wide=false,getValue=null}={}){
  return new Promise(res=>{
    _mdlResolve=res;_mdlMode='custom';_mdlCustomResult=null;
    $('mdlTitle').textContent=title;
    const m=$('mdlMsg');if(msg){m.style.display='block';m.textContent=msg;}else m.style.display='none';
    $('mdlBody').style.display='none';
    const slot=$('mdlSlot');slot.style.display='block';slot.innerHTML=slotHTML;
    if(wide)$('mdlBox').classList.add('mdl-wide');
    $('mdlOKBtn').textContent=okText;
    $('mdlBack').classList.add('open');
    // getValue: 확인 누를 때 결과 계산
    if(getValue) _mdlGetter=getValue; else _mdlGetter=null;
    renderIcons();
  });
}
let _mdlGetter=null;
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'&&$('mdlBack').classList.contains('open'))mdlCancel();
});

// ===== ONBOARDING (Firebase-style) =====
const ONB_ACTIVE={};  // {service: {location, ...}}
async function onbStatusAll(){
  const r=await api('GET','/api/onboarding/status');
  if(r.activations){for(const a of r.activations)ONB_ACTIVE[a.service]=a;}
}
function onbIsActive(service){return !!ONB_ACTIVE[service];}
function onbApply(service){
  // 히어로 vs 바디 토글
  const hero=$('onb-'+service),body=$(`onb-${service}-body`);
  if(!hero||!body)return;
  if(onbIsActive(service)){
    hero.style.display='none';body.style.display='';
    // 위치 태그 표시
    const tag=$('dbLocTag');
    if(service==='database'&&tag){
      const loc=ONB_ACTIVE[service]?.location||'auto';
      const locName={
        'asia-northeast3':'서울','asia-northeast1':'도쿄','asia-southeast1':'싱가포르',
        'us-central1':'아이오와','europe-west1':'벨기에','auto':'자동 선택'
      }[loc]||loc;
      tag.textContent='📍 '+locName;
    }
  } else {
    hero.style.display='';body.style.display='none';
  }
  renderIcons();
}
async function onbStart(service){
  if(service==='database'){
    // DB 리전 목록 가져오기
    const info=await api('GET','/api/onboarding/db-info');
    if(info.error)return toast(info.error,0);
    const locs=info.locations;
    // 추천을 선택 상태로
    let sel=locs.find(l=>l.recommended)?.id||locs[0].id;
    const html=`
      <div style="font-size:13px;color:var(--text2);line-height:1.5;margin-bottom:8px">
        가장 가까운 위치를 자동으로 감지했어요. 원하는 위치를 선택하세요.
        <br><span style="color:var(--text3);font-size:11px">한번 선택하면 이후 변경 시 데이터 마이그레이션이 필요할 수 있음.</span>
      </div>
      <div class="rgn-list" id="rgnList">
        ${locs.map(l=>`
          <div class="rgn-item ${l.id===sel?'sel':''}" data-loc="${l.id}" onclick="onbPickLoc('${l.id}')">
            <span class="rgn-flag">${l.flag}</span>
            <span class="rgn-name">${l.name}${l.recommended?'<span class="rgn-rec">추천</span>':''}</span>
            <span class="rgn-ping">~${l.ping_ms}ms</span>
          </div>
        `).join('')}
      </div>
      <div style="margin-top:12px;font-size:11px;color:var(--text3);text-align:center">
        💡 데이터베이스는 <b>API 키별로 완전 격리</b>됨. 다른 유저 데이터에 접근 불가.
      </div>
    `;
    window._onbPickedLoc=sel;
    const picked=await customModal('데이터베이스 시작하기',{
      msg:'',slotHTML:html,okText:'활성화',wide:true,
      getValue:()=>window._onbPickedLoc
    });
    if(!picked)return;
    const r=await api('POST','/api/onboarding/activate',{service:'database',location:picked});
    if(r.error)return toast(r.error,0);
    ONB_ACTIVE.database={service:'database',location:picked};
    toast('데이터베이스 활성화 완료');onbApply('database');
    // 첫 로드
    dbTblLoad?.();
  }
}
function onbPickLoc(id){
  window._onbPickedLoc=id;
  document.querySelectorAll('#rgnList .rgn-item').forEach(el=>{
    el.classList.toggle('sel', el.dataset.loc===id);
  });
}
async function onbReset(service){
  if(!await customConfirm('온보딩 재설정','활성화를 해제하고 시작 화면을 다시 볼까요? 데이터는 유지됩니다.',{okText:'재설정'}))return;
  await api('DELETE','/api/onboarding/deactivate/'+service);
  delete ONB_ACTIVE[service];
  onbApply(service);
  toast('재설정됨');
}

// ===== SQL EDITOR (in Database page) =====
const SQLEX={
  create:`CREATE TABLE IF NOT EXISTS products (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  name TEXT,\n  price INTEGER,\n  category TEXT\n);`,
  full:`CREATE TABLE IF NOT EXISTS products (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, price INTEGER, category TEXT);\nINSERT INTO products (name,price,category) VALUES ('아이폰',1500000,'전자기기'),('맥북',2800000,'컴퓨터'),('에어팟',350000,'악세서리');\nSELECT * FROM products;`
};
async function sqlRun(){const q=V('sqlTA');if(!q)return;const r=await api('POST','/api/s3/sql',{query:q});const e=$('sqlRes');
if(r.error){e.innerHTML=`<div class="code" style="border-left:2px solid var(--red)">${esc(r.error)}</div>`;return;}
if(r.rows?.length){const cols=Object.keys(r.rows[0]);e.innerHTML=`<div style="font-size:10px;color:var(--green);margin-bottom:6px">✓ ${r.rows.length}행 · ${r.duration_ms||0}ms${r.truncated?' · <span style="color:var(--yellow)">잘림</span>':''}</div><table class="tbl"><tr>${cols.map(c=>`<th>${esc(c)}</th>`).join('')}</tr>${r.rows.map(row=>`<tr>${cols.map(c=>`<td>${row[c]===null?'<span style="color:var(--dim)">NULL</span>':esc(row[c])}</td>`).join('')}</tr>`).join('')}</table>`;}
else e.innerHTML=`<div class="code" style="border-left:2px solid var(--green)">✓ ${r.affected||0}행 영향 · ${r.duration_ms||0}ms</div>`;}
document.addEventListener('keydown',e=>{if((e.ctrlKey||e.metaKey)&&e.key==='Enter'){const pg=$('pg-database');if(pg&&pg.classList.contains('show-page')){e.preventDefault();sqlRun();}}});

// ===== TABLE EDITOR =====
let _dbCurTbl=null,_dbCurCols=[],_dbCurPk=null;
async function dbTblLoad(){
  const el=$('dbTblListEl');el.innerHTML='<div class="empty">로딩 중...</div>';
  const r=await api('GET','/api/db/tables');
  if(r.error){el.innerHTML=`<div class="code" style="border-left:2px solid var(--red)">${esc(r.error)}</div>`;return;}
  if(!r.tables?.length){el.innerHTML='<div class="empty">테이블이 없습니다. SQL 에디터에서 <code>CREATE TABLE</code>을 실행하세요.</div>';return;}
  el.innerHTML=`<table class="tbl"><tr><th>이름</th><th>행 개수</th><th></th></tr>${r.tables.map(t=>`
    <tr><td><strong>${esc(t.name)}</strong></td><td class="mono">${t.rows|0}</td>
    <td style="display:flex;gap:6px"><button class="btn btn-p btn-sm" onclick="dbTblOpen(${JSON.stringify(t.name)})"><i data-lucide="pencil"></i> 편집</button></td></tr>
  `).join('')}</table>`;renderIcons();
}
async function dbTblOpen(name){
  _dbCurTbl=name;
  const r=await api('GET','/api/db/table/'+encodeURIComponent(name)+'?limit=200');
  if(r.error){toast(r.error,0);return;}
  _dbCurCols=r.columns;
  _dbCurPk=r.columns.find(c=>c.pk)?.name||r.columns[0].name;
  $('dbTblEditCard').style.display='';
  $('dbTblEditTitle').textContent='📋 '+name;
  $('dbTblCount').textContent=`${r.total}행 · PK: ${_dbCurPk}`;
  const cols=r.columns.map(c=>c.name);
  const rows=r.rows;
  const html=`<table class="tbl"><tr>${cols.map(c=>{
    const info=r.columns.find(x=>x.name===c);
    return `<th>${esc(c)}${info.pk?' 🔑':''}<div style="font-size:10px;color:var(--dim);font-weight:400;text-transform:none;margin-top:2px">${esc(info.type||'')}</div></th>`;
  }).join('')}<th></th></tr>
  ${rows.map(row=>`<tr>${cols.map(c=>{
    const v=row[c];
    const disp=v===null?'<span class="db-null">NULL</span>':esc(v);
    return `<td class="db-editable" contenteditable="true" data-col="${esc(c)}" data-pk="${esc(row[_dbCurPk])}" data-orig="${v===null?'':esc(v)}" onblur="dbCellEdit(this)">${disp}</td>`;
  }).join('')}<td><button class="btn btn-d btn-sm" onclick="dbRowDel(${JSON.stringify(String(row[_dbCurPk]))})"><i data-lucide="trash-2"></i></button></td></tr>`).join('')}
  </table>${rows.length===0?'<div class="empty">빈 테이블</div>':''}`;
  $('dbTblEditEl').innerHTML=html;renderIcons();
}
async function dbCellEdit(td){
  const col=td.dataset.col,pk=td.dataset.pk,orig=td.dataset.orig;
  let nv=td.textContent.trim();if(nv==='NULL')nv=null;
  if(String(nv)===orig)return;
  const changes={};changes[col]=nv;
  const r=await api('PUT','/api/db/table/'+encodeURIComponent(_dbCurTbl)+'/row',{pk_col:_dbCurPk,pk_val:pk,changes});
  if(r.error){toast(r.error,0);dbTblOpen(_dbCurTbl);return;}
  td.dataset.orig=nv===null?'':nv;
  toast('저장됨');
}
async function dbRowDel(pk){
  if(!await customConfirm('행 삭제',`PK=${pk} 행을 삭제할까요?`,{okText:'삭제',danger:true}))return;
  const r=await api('DELETE','/api/db/table/'+encodeURIComponent(_dbCurTbl)+'/row',{pk_col:_dbCurPk,pk_val:pk});
  if(r.error)return toast(r.error,0);
  toast('삭제됨');dbTblOpen(_dbCurTbl);
}
async function dbRowNew(){
  if(!_dbCurTbl)return;
  // 빈 값으로 시작하는 컬럼 목록. AUTOINCREMENT는 생략 유도.
  const editable=_dbCurCols.filter(c=>!(c.pk&&/INT/i.test(c.type||'')));
  const inputs=await customPrompt('새 행 추가',{
    msg:`${_dbCurTbl}에 새 행을 추가합니다. 값을 JSON으로 입력해요.`,
    placeholder:JSON.stringify(Object.fromEntries(editable.map(c=>[c.name,''])),null,0),
    defaultVal:JSON.stringify(Object.fromEntries(editable.map(c=>[c.name,''])))
  });
  if(inputs===null)return;
  let obj;try{obj=JSON.parse(inputs);}catch{return toast('JSON 형식이 아님',0);}
  const r=await api('POST','/api/db/table/'+encodeURIComponent(_dbCurTbl)+'/row',obj);
  if(r.error)return toast(r.error,0);
  toast('추가됨');dbTblOpen(_dbCurTbl);
}
async function dbTblNew(){
  const name=await customPrompt('새 테이블',{placeholder:'my_table',msg:'테이블 이름을 입력하면 기본 스키마(id, name)로 생성됩니다.'});
  if(!name)return;
  const r=await api('POST','/api/s3/sql',{query:`CREATE TABLE ${name} (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT)`});
  if(r.error)return toast(r.error,0);
  toast('생성: '+name);dbTblLoad();
}
async function dbTblDrop(){
  if(!_dbCurTbl)return;
  if(!await customConfirm('테이블 삭제',`정말로 '${_dbCurTbl}' 테이블을 삭제할까요? 되돌릴 수 없음.`,{okText:'삭제',danger:true}))return;
  const r=await api('DELETE','/api/db/table/'+encodeURIComponent(_dbCurTbl));
  if(r.error)return toast(r.error,0);
  toast('삭제됨');$('dbTblEditCard').style.display='none';_dbCurTbl=null;dbTblLoad();
}

// ===== RLS =====
async function dbRlsLoad(){
  const el=$('dbRlsListEl');el.innerHTML='<div class="empty">로딩 중...</div>';
  const r=await api('GET','/api/db/rls');
  if(r.error){el.innerHTML=`<div class="code" style="border-left:2px solid var(--red)">${esc(r.error)}</div>`;return;}
  if(!r.policies?.length){el.innerHTML='<div class="empty">아직 정책 없음. 정책이 없으면 기본 허용.</div>';return;}
  el.innerHTML=`<table class="tbl"><tr><th>테이블</th><th>API 키</th><th>읽기</th><th>쓰기</th><th>생성일</th><th></th></tr>${r.policies.map(p=>`
    <tr>
      <td><strong>${esc(p.table_name)}</strong></td>
      <td class="mono">${p.api_key==='*'?'<span class="tag tag-b">모든 키</span>':esc(p.api_key.substring(0,14))+'...'}</td>
      <td><span class="tag tag-${p.allow_read?'g':'r'}">${p.allow_read?'허용':'차단'}</span></td>
      <td><span class="tag tag-${p.allow_write?'g':'r'}">${p.allow_write?'허용':'차단'}</span></td>
      <td style="color:var(--text3);font-size:11px">${esc(p.created_at||'')}</td>
      <td><button class="btn btn-d btn-sm" onclick="dbRlsDel(${p.id|0})"><i data-lucide="trash-2"></i></button></td>
    </tr>
  `).join('')}</table>`;renderIcons();
}
async function dbRlsAdd(){
  const t=V('rlsTbl');if(!t)return toast('테이블명 입력',0);
  const key=V('rlsKey')||'*';
  const rd=document.querySelector('[data-dd="rlsRead"] .dd-val').dataset.val==='1';
  const wr=document.querySelector('[data-dd="rlsWrite"] .dd-val').dataset.val==='1';
  const r=await api('POST','/api/db/rls',{table_name:t,api_key:key,allow_read:rd,allow_write:wr});
  if(r.error)return toast(r.error,0);
  toast('정책 추가');$('rlsTbl').value='';$('rlsKey').value='';dbRlsLoad();
}
async function dbRlsDel(id){
  if(!await customConfirm('정책 삭제','이 정책을 삭제할까요?',{okText:'삭제',danger:true}))return;
  await api('DELETE','/api/db/rls/'+id);toast('삭제됨');dbRlsLoad();
}
// 커스텀 드롭다운 선택 헬퍼 (rlsRead/rlsWrite용)
function ddPick(name,val,label){
  const dd=document.querySelector(`[data-dd="${name}"]`);if(!dd)return;
  const valEl=dd.querySelector('.dd-val');valEl.dataset.val=val;valEl.textContent=label;
  dd.querySelectorAll('.dd-opt').forEach(o=>o.classList.remove('sel'));
  event.target.classList.add('sel');
  dd.querySelector('.dd-trigger').classList.remove('open');
  dd.querySelector('.dd-menu').classList.remove('open');
}

