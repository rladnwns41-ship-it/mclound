  {cat:'Lambda',eps:[{m:'POST',p:'/api/lambda/functions',d:'함수 등록'},{m:'GET',p:'/api/lambda/functions',d:'목록'},{m:'POST',p:'/api/lambda/invoke',d:'실행'}]},
  {cat:'S3',eps:[{m:'POST',p:'/api/s3/buckets',d:'버킷 생성'},{m:'GET',p:'/api/s3/buckets',d:'목록'},{m:'PUT',p:'/api/s3/objects',d:'저장'},{m:'GET',p:'/api/s3/objects?bucket=X&key=Y',d:'조회'},{m:'DELETE',p:'/api/s3/objects',d:'삭제'},{m:'POST',p:'/api/s3/upload',d:'파일 업로드'},{m:'POST',p:'/api/s3/sql',d:'SQL 실행'}]},
  {cat:'Storage',eps:[{m:'POST',p:'/api/ebs/volumes',d:'EBS 볼륨'},{m:'PUT',p:'/api/ebs/data',d:'EBS 저장'},{m:'POST',p:'/api/cloudfront/store',d:'CF 저장'},{m:'POST',p:'/api/cloudformation/stacks',d:'임시 JSON'},{m:'POST',p:'/api/workspaces/upload',d:'파일 업로드'},{m:'POST',p:'/api/kinesis/classify',d:'파일 분류'},{m:'POST',p:'/api/emr/config',d:'EMR 설정'}]},
  {cat:'배포',eps:[{m:'POST',p:'/api/lightsail/deploy/json',d:'HTML 배포'},{m:'POST',p:'/api/eb/deploy',d:'앱 배포'},{m:'POST',p:'/api/route53/records',d:'DB 연결'},{m:'POST',p:'/api/elb/config',d:'LB 설정'}]},
  {cat:'보안',eps:[{m:'POST',p:'/api/vpc/rules',d:'VPC 규칙'},{m:'GET',p:'/api/vpc/rules',d:'규칙 목록'},{m:'POST',p:'/api/autoscaling/config',d:'트래픽 설정'}]},
  {cat:'모니터링',eps:[{m:'GET',p:'/api/cloudwatch/summary',d:'요약'},{m:'GET',p:'/api/cloudwatch/dashboard',d:'대시보드'},{m:'GET',p:'/api/cloudwatch/metrics',d:'상세 메트릭'}]},
];
function renderDocs(){$('docsContent').innerHTML=ENDPOINTS.map(c=>`<h3 style="font-size:14px;font-weight:600;margin:18px 0 8px">${c.cat}</h3>${c.eps.map(e=>`<div class="ep"><div class="ep-h" onclick="this.nextElementSibling.classList.toggle('open')"><span class="ep-m ${e.m==='GET'?'get':e.m==='POST'?'post':e.m==='PUT'?'put':'del'}">${e.m}</span><span class="ep-p">${e.p}</span><span class="ep-d">${e.d}</span></div><div class="ep-body"><div class="code">${e.m} ${e.p}</div></div></div>`).join('')}`).join('');}
renderDocs();

