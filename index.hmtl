// ===== AI SQL HELPER =====
async function aiSQL(){
  const p=V('aiPrompt');if(!p)return toast('설명을 입력하세요',0);
  toast('AI가 SQL 생성 중...');
  const r=await api('POST','/api/ai/sql',{prompt:p});
  console.log('AI SQL 응답:', r);
  if(r.error){
    const e=$('sqlRes');
    e.innerHTML=`<div class="code" style="border-left:2px solid var(--red);white-space:pre-wrap">${r.error}</div>`;
    toast('AI SQL 실패 - 아래 에러 확인',0);
    return;
  }
  if(!r.sql){
    const e=$('sqlRes');
    e.innerHTML=`<div class="code" style="border-left:2px solid var(--red)">응답에 sql 필드 없음: ${JSON.stringify(r)}</div>`;
    toast('AI SQL 응답 오류',0);
    return;
  }
  $('sqlTA').value=r.sql;
  toast('SQL 생성 완료! 실행 버튼을 눌러주세요');
}

