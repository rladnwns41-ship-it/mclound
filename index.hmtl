async function loadActivity(){
  const r=await api('GET','/api/activity/recent?limit=15');
  const el=$('activityLog');
  if(r.error||!r.activities?.length){el.innerHTML='<div class="empty">활동 없음</div>';return;}
  const statusColor=s=>s>=200&&s<300?'var(--green)':s>=400?'var(--red)':'var(--yellow)';
  el.innerHTML=r.activities.map(a=>`<div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px">
    <span style="width:6px;height:6px;border-radius:50%;background:${statusColor(a.status)};flex-shrink:0"></span>
    <span style="flex:1;color:var(--text)">${a.desc}</span>
    <span style="color:var(--text3);font-size:10px;font-family:var(--mono)">${a.duration_ms||0}ms</span>
    <span style="color:var(--text3);font-size:10px;white-space:nowrap">${(a.time||'').substring(11,19)}</span>
  </div>`).join('');
}

// ===== 서버 슬립 감지 =====
let _srvDead = false;
let _sleepCheckTimer = null;

let _failCount = 0;
function showSleepOverlay() {
  _failCount++;
  if (_failCount < 3) return; // 3번 연속 실패 후에만 표시
  if (_srvDead) return;
  _srvDead = true;
  const ov = document.getElementById('sleepOverlay');
  if (ov) { ov.style.display = 'flex'; }
  _startSleepRetry();
}

function hideSleepOverlay() {
  _srvDead = false;
  _failCount = 0;
  const ov = document.getElementById('sleepOverlay');
  if (ov) { ov.style.display = 'none'; }
  if (_sleepCheckTimer) { clearInterval(_sleepCheckTimer); _sleepCheckTimer = null; }
  document.getElementById('sleepRetryMsg').textContent = '';
}

let _retryCount = 0;
function _startSleepRetry() {
  if (_sleepCheckTimer) clearInterval(_sleepCheckTimer);
  _retryCount = 0;
  _sleepCheckTimer = setInterval(async () => {
    _retryCount++;
    const msg = document.getElementById('sleepRetryMsg');
    if (msg) msg.textContent = `자동 재시도 중... (${_retryCount}회)`;
    const ok = await _checkServer();
    if (ok) {
      if (msg) msg.textContent = '연결 복구됨!';
      setTimeout(hideSleepOverlay, 600);
    }
  }, 10000);
}

async function _checkServer() {
  try {
    const r = await fetch(B + '/api/cloudwatch/summary', {
      headers: { 'X-API-Key': K, 'ngrok-skip-browser-warning': 'true' },
      signal: AbortSignal.timeout(10000)
    });
    return r.ok;
  } catch { return false; }
}

async function retrySrv() {
  const msg = document.getElementById('sleepRetryMsg');
  if (msg) msg.textContent = '연결 시도 중...';
  const ok = await _checkServer();
  if (ok) {
    if (msg) msg.textContent = '연결 복구됨!';
    setTimeout(hideSleepOverlay, 600);
  } else {
    if (msg) msg.textContent = '❌ 아직 연결 안 됨. 서버를 확인해주세요.';
  }
}

// API 래퍼에 슬립 감지 통합
const _origApi = api;
api = async function(method, path, body, auth=true) {
  try {
    const o = { method, headers: { 'Content-Type': 'application/json', 'ngrok-skip-browser-warning': 'true' } };
    if (auth && K) o.headers['X-API-Key'] = K;
    if (body && method !== 'GET') o.body = JSON.stringify(body);
    o.signal = AbortSignal.timeout(15000);
    const r = await fetch(B + path, o);
    // 서버 응답 왔으면 슬립 해제
    _failCount = 0; if (_srvDead) hideSleepOverlay();
    return await r.json();
  } catch(e) {
    // 로그인 화면이 표시 중이면 슬립 오버레이 안 띄움
    const loginVisible = !document.getElementById('loginScr')?.classList.contains('hide');
    if (!loginVisible && K && B) {
      showSleepOverlay();
    }
    return { error: e.message };
  }
};

// 로그인 상태에서 주기적 서버 체크 (60초)
let _aliveTimer = null;
function startAliveCheck() {
  if (_aliveTimer) clearInterval(_aliveTimer);
  _aliveTimer = setInterval(async () => {
    if (!K || !B) return;
    const loginVisible = !document.getElementById('loginScr')?.classList.contains('hide');
    if (loginVisible) return;
    const ok = await _checkServer();
    if (!ok && !_srvDead) showSleepOverlay();
  }, 60000);
}

</script>
</body>
</html>
